<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <inset android:insetLeft="4dp" android:insetRight="4dp" android:insetTop="4dp" android:insetBottom="4dp">
            <layer-list>
                <item>
                    <shape android:shape="oval">
                        <solid android:color="#6200EE" />
                        <size android:width="24dp" android:height="24dp" />
                    </shape>
                </item>
                <item android:drawable="@android:drawable/checkbox_on_background" />
            </layer-list>
        </inset>
    </item>

    <item android:state_checked="false">
        <inset android:insetLeft="4dp" android:insetRight="4dp" android:insetTop="4dp" android:insetBottom="4dp">
            <shape android:shape="oval">
                <stroke android:width="2dp" android:color="#757575" />
                <solid android:color="@android:color/transparent" />
                <size android:width="24dp" android:height="24dp" />
            </shape>
        </inset>
    </item>
</selector>