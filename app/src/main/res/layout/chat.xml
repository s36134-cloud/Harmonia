<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#F3E5F5">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/layout_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/profile_image"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/ic_account"
                android:layout_marginEnd="12dp"
                />


            <TextView
                android:id="@+id/tv_partner_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="שם המשתמש"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#4A148C"
                android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/tv_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="95%"
                android:textColor="#2E7D32"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ImageView
            android:id="@+id/backhome"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_alignTop="@id/layout_header"
            android:layout_marginTop="20dp"
            android:src="@drawable/ic_chat"
            app:tint="#CE93D8"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <TextView
            android:id="@+id/tv_reason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/layout_header"
            android:layout_toStartOf="@id/backhome"
            android:layout_marginTop="8dp"
            android:layout_marginStart="52dp"
            android:text="שניכם אוהבים מוזיקת רוק וספרי מתח..."
            android:textColor="#666666"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btn_start_chat"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_below="@id/tv_reason"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="12dp"
            android:backgroundTint="#6200EE"
            android:text="שלח הודעה"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="20dp" />

    </RelativeLayout>
</androidx.cardview.widget.CardView>