<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#F9F7F2">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <!-- תמונת פרופיל עגולה -->
        <ImageView
            android:id="@+id/profile_image_chat_summary"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:textSize="24sp"
            android:layout_marginEnd="12dp"
            android:backgroundTint="#1A2B3C"
            android:src="@drawable/ic_person"
            app:tint="#DCCCAC"/>

        <!-- שם + הודעה אחרונה -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_partner_name_summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="שם המשתמש"
                android:textSize="16sp"
                android:textColor="#1A2B3C"
                android:fontFamily="@font/myfont4"

                />

            <TextView
                android:id="@+id/tv_last_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Last message..."
                android:textSize="13sp"
                android:fontFamily="@font/myfont4"
                android:layout_marginTop="2dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="#1A2B3C"
                />

        </LinearLayout>



    </LinearLayout>
</androidx.cardview.widget.CardView>