<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main"
    android:orientation="vertical"
    android:background="@drawable/backgroundbooks">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="25dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"
            app:theme="@style/MySearchFont"
            android:background="@drawable/comment_bubble"

            >

            <ImageView
                android:id="@+id/imageViewbooksearch"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_back"
                android:contentDescription="Back"
                android:clickable="true"
                android:focusable="true"
                app:tint="#1A2B3C"
                />

            <androidx.appcompat.widget.SearchView
                android:id="@+id/searchViewbook"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:iconifiedByDefault="false"
                app:queryHint="search book"
                app:queryBackground="@android:color/transparent"
                android:layoutDirection="ltr"
                />
        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/searchResultsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="8dp"
        android:clipToPadding="false" />


    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDoneBooks"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:paddingHorizontal="48dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:text="Done"
        android:textAllCaps="false"
        android:textSize="17sp"
        app:backgroundTint="#FFF1E0"
        app:cornerRadius="28dp"
        app:elevation="0dp"
        app:strokeColor="#FBE8CE"
        app:strokeWidth="1.5dp"
        app:rippleColor="#F5F5F5"
        android:textColor="#1A2B3C"
        android:backgroundTint="#FBE8CE"
        android:fontFamily="@font/myfont4"
        android:visibility="gone"
        />

</LinearLayout>